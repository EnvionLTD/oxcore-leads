# Admin credentials for the /admin panel
ADMIN_USER=admin
ADMIN_PASS=your_password_here

# Random string — signs admin session tokens
# Generate one at: https://generate-secret.vercel.app/32
JWT_SECRET=your_random_secret_here

# Added automatically when you connect a Blob store in Vercel dashboard
# Storage → Create Database → Blob → Link to project
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxx

# Meta Conversions API — server-side lead tracking
# Create at: Business Settings → System Users → Generate Token (ads_management permission)
# Without this, leads only track client-side (ad blockers / iOS will miss them)
META_CAPI_TOKEN=your_meta_system_user_token_here
