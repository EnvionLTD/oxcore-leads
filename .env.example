# Admin credentials for the /admin panel
ADMIN_USER=admin
ADMIN_PASS=your_password_here

# Random string — used to sign admin session tokens
# Generate one at: https://generate-secret.vercel.app/32
JWT_SECRET=your_random_secret_here

# Airtable — https://airtable.com
# Create a base called "Oxcore Leads", add a table called "Leads"
# Columns: Name, Phone, Postcode, Address, Service (all Single line text)
AIRTABLE_API_KEY=your_airtable_personal_access_token
AIRTABLE_BASE_ID=your_airtable_base_id
